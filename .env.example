# Memory Hub Configuration
# Copy this file to .env and fill in your values

# ── Server ──────────────────────────────────────────
MEMORY_HUB_HOST=127.0.0.1
MEMORY_HUB_PORT=8765

# ── AI Providers (for conversation analysis) ────────
# At least one provider is needed for AI-powered features
# (summarization, importance scoring, memory extraction)

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Other providers (Qwen, Kimi, MiniMax, GLM)
# Configure via Web UI Settings page or backend/data/ai_config.json
